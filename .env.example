# ChainScape Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=chainscape
DB_PASSWORD=your_secure_password_here
DB_NAME=chainscape

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Solana Configuration
# =============================================================================
# Network: 'mainnet-beta', 'devnet', or 'testnet'
SOLANA_NETWORK=devnet

# RPC endpoints (use your own for production)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Backup RPC (optional but recommended for production)
SOLANA_BACKUP_RPC_URL=

# CSGP Token mint address (set after token creation)
TOKEN_MINT_ADDRESS=

# Mint authority private key (base58 encoded)
# WARNING: Keep this secure! Use HSM or secrets manager in production
MINT_AUTHORITY_KEY=

# =============================================================================
# Game Server Configuration
# =============================================================================
GAME_SERVER_PORT=43594
WS_PORT=43595

# Server name and world number
SERVER_NAME=ChainScape
WORLD_NUMBER=1

# =============================================================================
# Web Client Configuration
# =============================================================================
# URL for the game WebSocket connection (client-side)
WS_URL=ws://localhost:43595/ws

# API base URL for web client
API_BASE_URL=http://localhost:8080

# =============================================================================
# Security Configuration
# =============================================================================
# JWT secret for session tokens (generate a strong random string)
JWT_SECRET=

# Rate limiting
MAX_WITHDRAWALS_PER_HOUR=5
MAX_WITHDRAWALS_PER_DAY=20

# =============================================================================
# Monitoring Configuration
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Prometheus scrape interval
PROMETHEUS_SCRAPE_INTERVAL=15s

# =============================================================================
# SSL Configuration (Production)
# =============================================================================
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# =============================================================================
# Discord Webhook (Optional - for alerts)
# =============================================================================
DISCORD_WEBHOOK_URL=
ALERT_CHANNEL_WEBHOOK=

# =============================================================================
# Development Settings
# =============================================================================
# Enable debug logging
DEBUG=false

# Skip certain security checks in development
DEV_MODE=false
