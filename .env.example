# ChainScape Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env or keypair files to git

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=chainscape
DB_PASSWORD=your_secure_password_here
DB_NAME=chainscape

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Solana Configuration
# =============================================================================
# Network: 'mainnet-beta', 'devnet', or 'testnet'
SOLANA_NETWORK=devnet

# RPC endpoint - use your own private RPC (Helius, QuickNode, etc.)
# DO NOT use public endpoints in production
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Backup RPC (optional but recommended)
SOLANA_BACKUP_RPC_URL=

# =============================================================================
# Treasury / Mint Authority
# =============================================================================
# Public key of the treasury wallet (safe to share)
TREASURY_PUBLIC_KEY=

# Path to keypair file (keep this file secure, never commit)
KEYPAIR_PATH=./keypair.json

# =============================================================================
# Token Configuration
# =============================================================================
# CSGP Token mint address (set after token creation)
TOKEN_MINT_ADDRESS=

# =============================================================================
# Game Server Configuration
# =============================================================================
GAME_SERVER_PORT=43594
WS_PORT=43595
SERVER_NAME=ChainScape
WORLD_NUMBER=1

# =============================================================================
# Web Client Configuration
# =============================================================================
WS_URL=ws://localhost:43595/ws
API_BASE_URL=http://localhost:8080

# =============================================================================
# Security Configuration
# =============================================================================
JWT_SECRET=generate_a_strong_random_string_here

# Rate limiting
MAX_WITHDRAWALS_PER_HOUR=5
MAX_WITHDRAWALS_PER_DAY=20

# =============================================================================
# Monitoring (Optional)
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_password

# =============================================================================
# Development Settings
# =============================================================================
DEBUG=false
DEV_MODE=true
